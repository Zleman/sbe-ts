"// AUTO-GENERATED — do not edit. Re-run sbe-ts-cli to regenerate.
// Package: groups  Schema ID: 6  Version: 0
import { MessageFlyweight, GroupIterator, GroupWriter } from 'sbe-ts';

class LegsEntry extends MessageFlyweight {
  static readonly BLOCK_LENGTH = 4;

  legId(): number { return this.view.getUint16(this.offset + 0, true); }
  weight(): number { return this.view.getUint16(this.offset + 2, true); }

  setLegId(v: number): this { this.view.setUint16(this.offset + 0, v, true); return this; }
  setWeight(v: number): this { this.view.setUint16(this.offset + 2, v, true); return this; }

  absoluteEnd(): number {
    return this.offset + LegsEntry.BLOCK_LENGTH;
  }
}
class FillsEntry extends MessageFlyweight {
  static readonly BLOCK_LENGTH = 6;

  private static readonly _EMPTY = new ArrayBuffer(0);
  private readonly _legsEntry = new LegsEntry(FillsEntry._EMPTY, 0);
  private readonly _legsIter = new GroupIterator(this._legsEntry);
  private readonly _legsWriter = new GroupWriter(this._legsEntry);

  price(): number { return this.view.getUint32(this.offset + 0, true); }
  quantity(): number { return this.view.getUint16(this.offset + 4, true); }

  setPrice(v: number): this { this.view.setUint32(this.offset + 0, v, true); return this; }
  setQuantity(v: number): this { this.view.setUint16(this.offset + 4, v, true); return this; }

  legs(): GroupIterator<LegsEntry> {
    const hdrOff = this.offset + FillsEntry.BLOCK_LENGTH;
    const view = this.view;
    const numInGroup = view.getUint16(hdrOff + 2, true);
    return this._legsIter.reset(view.buffer, hdrOff + 4, numInGroup);
  }

  legsCount(numInGroup: number): GroupWriter<LegsEntry> {
    const hdrOff = this.offset + FillsEntry.BLOCK_LENGTH;
    const view = this.view;
    view.setUint16(hdrOff, LegsEntry.BLOCK_LENGTH, true);
    view.setUint16(hdrOff + 2, numInGroup, true);
    return this._legsWriter.reset(view.buffer, hdrOff + 4, numInGroup);
  }

  absoluteEnd(): number {
    const hdr0 = (this.offset + FillsEntry.BLOCK_LENGTH);
    const n0 = this.view.getUint16(hdr0 + 2, true);
    return this._legsIter.reset(this.view.buffer, hdr0 + 4, n0).absoluteEnd();
  }
}

export class TradeDecoder extends MessageFlyweight {
  static readonly BLOCK_LENGTH = 8;
  static readonly TEMPLATE_ID  = 1;
  static readonly SCHEMA_ID    = 6;
  static readonly VERSION      = 0;

  private static readonly _EMPTY = new ArrayBuffer(0);
  private readonly _fillsEntry = new FillsEntry(TradeDecoder._EMPTY, 0);
  private readonly _fillsIter = new GroupIterator(this._fillsEntry);

  override wrap(buffer: ArrayBufferLike, offset: number): this {
    super.wrap(buffer, offset);
    this.cursor = TradeDecoder.BLOCK_LENGTH;
    return this;
  }

  tradeId(): bigint { return this.view.getBigUint64(this.offset + 0, true); }

  fills(): GroupIterator<FillsEntry> {
    const hdrOff = this.offset + TradeDecoder.BLOCK_LENGTH;
    const view = this.view;
    const numInGroup = view.getUint16(hdrOff + 2, true);
    return this._fillsIter.reset(view.buffer, hdrOff + 4, numInGroup);
  }

  // VarData fields must be read in schema-declaration order (cursor advances on each call).
  comment(): Uint8Array {
    const pos = this._fillsIter.absoluteEnd();
    const len = this.view.getUint32(pos, true);
    const data = new Uint8Array(this.view.buffer, pos + 4, len);
    this.cursor = (pos + 4 + len) - this.offset;
    return data;
  }
  // VarData fields must be read in schema-declaration order (cursor advances on each call).
  metadata(): Uint8Array {
    const pos = this.offset + this.cursor;
    const len = this.view.getUint32(pos, true);
    const data = new Uint8Array(this.view.buffer, pos + 4, len);
    this.cursor += 4 + len;
    return data;
  }
}

export class TradeEncoder extends MessageFlyweight {
  static readonly BLOCK_LENGTH = 8;

  private static readonly _EMPTY = new ArrayBuffer(0);
  private readonly _fillsEntry = new FillsEntry(TradeEncoder._EMPTY, 0);
  private readonly _fillsWriter = new GroupWriter(this._fillsEntry);

  override wrap(buffer: ArrayBufferLike, offset: number): this {
    super.wrap(buffer, offset);
    this.cursor = TradeEncoder.BLOCK_LENGTH;
    return this;
  }

  setTradeId(v: bigint): this { this.view.setBigUint64(this.offset + 0, v, true); return this; }

  fillsCount(numInGroup: number): GroupWriter<FillsEntry> {
    const hdrOff = this.offset + TradeEncoder.BLOCK_LENGTH;
    const view = this.view;
    view.setUint16(hdrOff, FillsEntry.BLOCK_LENGTH, true);
    view.setUint16(hdrOff + 2, numInGroup, true);
    return this._fillsWriter.reset(view.buffer, hdrOff + 4, numInGroup);
  }

  setComment(data: Uint8Array): this {
    if (data.length > 4294967295) throw new RangeError(\`comment: payload (\${data.length} bytes) exceeds uint32 prefix capacity\`);
    const pos = this._fillsWriter.absoluteEnd();
    this.view.setUint32(pos, data.length, true);
    new Uint8Array(this.view.buffer, pos + 4, data.length).set(data);
    this.cursor = (pos + 4 + data.length) - this.offset;
    return this;
  }
  setMetadata(data: Uint8Array): this {
    if (data.length > 4294967295) throw new RangeError(\`metadata: payload (\${data.length} bytes) exceeds uint32 prefix capacity\`);
    const pos = this.offset + this.cursor;
    this.view.setUint32(pos, data.length, true);
    new Uint8Array(this.view.buffer, pos + 4, data.length).set(data);
    this.cursor += 4 + data.length;
    return this;
  }
}
"
`;


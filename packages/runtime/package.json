{
  "name": "sbe-ts",
  "version": "0.1.0",
  "description": "Zero-allocation Simple Binary Encoding runtime for TypeScript",
  "keywords": ["sbe", "simple-binary-encoding", "binary", "flyweight", "finance", "low-latency"],
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/zleman/sbe-ts.git" },
  "bugs":       { "url": "https://github.com/zleman/sbe-ts/issues" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": { "import": "./dist/index.d.mts", "require": "./dist/index.d.cts" },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown",
    "pretest": "tsgo --noEmit && tsgo --noEmit --project tsconfig.test.json",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "typecheck": "tsgo --noEmit",
    "typecheck:legacy": "tsc --noEmit"
  },
  "sideEffects": false,
  "engines": { "node": ">=22" },
  "devDependencies": {
    "tsdown": "^0.21.10",
    "vitest": "^2.1.0",
    "typescript": "^6.0.3"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2025", "ESNext.Disposable"],
    "types": [],
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedDeclarations": true,
    "noUncheckedIndexedAccess": true,
    "erasableSyntaxOnly": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "test"]
}
